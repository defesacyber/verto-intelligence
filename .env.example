# ============================================================
# KREO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA commite o arquivo .env real no git.
# ============================================================

# ------------------------------------------------------------
# FRONTEND (Vercel) — obrigatórias para o build
# ------------------------------------------------------------
VITE_SUPABASE_URL=https://seu-projeto-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua-chave-aqui

# ------------------------------------------------------------
# ADMIN KEY — LOCAL SCRIPTS ONLY
# Usada pelos scripts em /scripts/ (verify-users, reset-passwords, etc.)
# NUNCA adicione esta variável ao Vercel ou qualquer plataforma de deploy.
# Configure no Supabase Dashboard: Settings → Edge Functions → Secrets
# ------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ------------------------------------------------------------
# EDGE FUNCTIONS (Supabase Dashboard → Settings → Edge Functions → Secrets)
# NÃO adicione estas variáveis ao Vercel — vão para o Supabase.
# ------------------------------------------------------------
# SUPABASE_URL=https://seu-projeto-id.supabase.co
# SUPABASE_ANON_KEY=sua-anon-key
# SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
# ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# Integrações opcionais (configurar no Supabase conforme features habilitadas):
# RESEND_API_KEY=sua-chave-resend
# FIRECRAWL_API_KEY=sua-chave-firecrawl
# DATAZAP_API_KEY=sua-chave-datazap
# FIPEZAP_API_KEY=sua-chave-fipezap
# SECOVI_API_KEY=sua-chave-secovi
# ADEMI_API_KEY=sua-chave-ademi

# ------------------------------------------------------------
# MONITORAMENTO & ANALYTICS (Vercel, opcionais)
# ------------------------------------------------------------
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
# VITE_MIXPANEL_TOKEN=seu-token
